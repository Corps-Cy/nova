{
  "name": "nova",
  "version": "0.9.0",
  "description": "Personal CLI toolkit for freelancers",
  "bin": {
    "nova": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts --external react",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
